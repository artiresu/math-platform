# See https://help.github.com/articles/ignoring-files/

# Dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js build & cache
/.next/
/out/
/build
.turbo

# Testing
/coverage

# Environment & secrets (never commit API keys)
.env
.env.*
!.env.example

# Vercel / hosting
.vercel

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# TypeScript
*.tsbuildinfo

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Editor / local tooling (keep shared .vscode if you commit team settings)
.idea/
*.swp
*.swo
*~

# Prisma / local databases
/prisma/*.db
/prisma/*.db-journal

# Optional: uncomment if you do not want to share Cursor-only local state
# .cursor/
