# Copy to .env.local for local secrets (never commit .env.local)

# SQLite (default local dev). For production, use PostgreSQL, e.g.:
# DATABASE_URL="postgresql://user:password@localhost:5432/math_platform"
DATABASE_URL="file:./dev.db"

# NEXT_PUBLIC_APP_URL=http://localhost:3000

