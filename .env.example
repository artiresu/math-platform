# Copy to .env for local dev (never commit .env)
#   Windows: copy .env.example .env
#   macOS/Linux: cp .env.example .env
# Next.js also reads .env.local if you prefer that name for overrides.

# SQLite (default local dev). For production, use PostgreSQL, e.g.:
# DATABASE_URL="postgresql://user:password@localhost:5432/math_platform"
DATABASE_URL="file:./dev.db"

# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth (when auth is wired up)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# AUTH_SECRET=  # openssl rand -base64 32
